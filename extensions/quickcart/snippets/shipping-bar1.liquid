<style>
  /* SECTION */
  .shipping-progress {
    padding: 16px 12px 12px 16px;
    background: #ffffff;
    margin: 3px 1rem 0.2rem;
  }

  /* TOP */
  .shipping-progress__top {
    display: block;
  }

  /* BAR */
  .shipping-progress__bar {
    width: 100%;
    height: 8px;
    margin-bottom: 8px;
    border-radius: 999px;
    {% comment %} overflow: hidden; {% endcomment %}
    background: #d6dde7;
  }

  /* FILL (WITH STRIPES ANIMATION) */
  .shipping-progress__fill {
    position: relative;
    width: 81%; /* you can change dynamically later */
    height: 100%;
    border-radius: inherit;

    /* Base gradient */
    background: linear-gradient(90deg, #104cc1, #3b82f6);

    /* Moving stripes */
    background-image: repeating-linear-gradient(45deg, #ffffeea6 0px, #ffffeea6 10px, transparent 10px, transparent 20px);

    background-size: 30px 40px;

    /* Animation */
    animation: moveStripes 2s linear infinite;

    /* Smooth width change (future dynamic use) */
    transition: width 0.4s ease;
  }

  /* STRIPES ANIMATION */
  @keyframes moveStripes {
    from {
      background-position: 0 0;
    }
    to {
      background-position: 40px 0;
    }
  }

  /* ICON */
  .shipping-progress__fill-icon {
    position: absolute;
    top: 50%;
    right: -8px;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    transform: translateY(-50%);
    background: #fff;
  }

  /* TEXT */
  .shipping-progress__text {
    margin: 0;
    color: #000;
    font-size: var(--font-size-1);
    line-height: 1.75;
    text-align: center;
    font-family: var(--font-family-one);
    font-weight: 500;
  }

  .shipping-progress__text strong {
    display: block;
    margin-top: 3px;
    color: #000;
    font-size: 17px;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;

  }
</style>

<div class="shipping-progress" aria-label="Free shipping progress" data-shipping-progress style="display: none;">
  <div class="shipping-progress__top">
    <div class="shipping-progress__bar">
      <div class="shipping-progress__fill">
        <span class="shipping-progress__fill-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path
                d="M3.5 6.5H13.5V16.5H3.5V6.5ZM13.5 9H17.2L20.5 12.5V16.5H13.5V9ZM7 18.2C7 19.19 6.19 20 5.2 20C4.21 20 3.4 19.19 3.4 18.2C3.4 17.21 4.21 16.4 5.2 16.4C6.19 16.4 7 17.21 7 18.2ZM18.6 18.2C18.6 19.19 17.79 20 16.8 20C15.81 20 15 19.19 15 18.2C15 17.21 15.81 16.4 16.8 16.4C17.79 16.4 18.6 17.21 18.6 18.2Z"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </div>

    <p class="shipping-progress__text">You got Free Shipping</p>
  </div>
</div>
