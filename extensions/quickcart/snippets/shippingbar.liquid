{% assign free_shipping_threshold = limit | default: 10000 %}
{% assign cart_total = cart.total_price %}

{% assign progress = cart_total | times: 100.0 | divided_by: free_shipping_threshold %}
{% if progress > 100 %}
  {% assign progress = 100 %}
{% endif %}

{% assign remaining_amount = free_shipping_threshold | minus: cart_total %}

<style>
  .cdp-freeshipping-box {
    margin: 10px 0;
    padding: 12px 16px;
    background-color: var(--body_background_color, #f9f9f9);
    border-radius: var(--border_radius, 8px);
    text-align: center;
    font-family: inherit;
  }
  .cdp-freeshipping-text {
    font-size: 14px;
    font-weight: 500;
    color: var(--text_color, #333);
    margin-bottom: 8px;
  }
  .cdp-freeshipping-text strong {
    font-weight: 700;
    color: var(--bg_color, #111);
  }
  .cdp-freeshipping-bar-container {
    width: 100%;
    height: 8px;
    background-color: #e0e0e0;
    border-radius: 10px;
    overflow: hidden;
  }
  .cdp-freeshipping-progress {
    height: 100%;
    background-color: var(--bg_color, #000);
    border-radius: 10px;
    transition: width 0.3s ease;
  }
  .cdp-freeshipping-success {
    color: #27ae60;
    font-weight: 600;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
</style>

<div class="cdp-freeshipping-box" data-threshold="{{ free_shipping_threshold }}">
  <div class="cdp-freeshipping-text cdp-fs-text-js">
    {% if progress >= 100 %}
      <div class="cdp-freeshipping-success">
        <svg fill="currentColor" viewBox="0 0 20 20" width="16" height="16">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
        </svg>
        <span>You've unlocked Free Shipping!</span>
      </div>
    {% else %}
      <span
        >You are <strong>{{ remaining_amount | money_without_trailing_zeros }}</strong> away from Free Shipping.</span
      >
    {% endif %}
  </div>

  <div class="cdp-freeshipping-bar-container">
    <div class="cdp-freeshipping-progress cdp-fs-progress-js" style="width: {{ progress }}%;"></div>
  </div>
</div>

<script>
  (function () {
    if (window._fsBarReady) return;
    window._fsBarReady = true;

    // Helper to format money natively
    function formatMoney(cents) {
      const moneyFormat =
        document.querySelector('[data-money-format]')?.getAttribute('data-money-format') || '${{amount}}';
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        let formatted = window.Shopify.formatMoney(cents, moneyFormat);
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = formatted;
        if (tempDiv.children.length > 0) {
          Array.from(tempDiv.childNodes).forEach((node) => {
            if (node.nodeType === 3) {
              node.textContent = node.textContent.replace(/\.00$/, '').replace(/\.0$/, '');
            }
          });
          formatted = tempDiv.innerHTML;
        } else {
          formatted = formatted.replace(/\.00$/, '').replace(/\.0$/, '');
        }
        return formatted.replace(/Rs\.?/g, '₹');
      }
      return '₹' + (cents / 100).toLocaleString('en-IN', { maximumFractionDigits: 0 });
    }

    async function updateFsBar() {
      try {
        const res = await fetch('/cart.js', { headers: { Accept: 'application/json' } });
        const cart = await res.json();
        const subtotal = cart.total_price || 0;

        document.querySelectorAll('.cdp-freeshipping-box').forEach((box) => {
          const threshold = parseInt(box.getAttribute('data-threshold'), 10) || 10000;
          let progress = (subtotal / threshold) * 100;
          if (progress > 100) progress = 100;

          const progBar = box.querySelector('.cdp-fs-progress-js');
          const textBox = box.querySelector('.cdp-fs-text-js');

          if (progBar) {
            progBar.style.width = progress + '%';
            if (progress >= 100) {
              progBar.style.backgroundColor = '#27ae60';
            } else {
              progBar.style.backgroundColor = 'var(--bg_color, #000)';
            }
          }

          if (textBox) {
            if (progress >= 100) {
              textBox.innerHTML = `
                <div class="cdp-freeshipping-success">
                  <svg fill="currentColor" viewBox="0 0 20 20" width="16" height="16"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                  <span>You've unlocked Free Shipping!</span>
                </div>
              `;
            } else {
              const remaining = threshold - subtotal;
              textBox.innerHTML = `<span>You are <strong>${formatMoney(
                remaining
              )}</strong> away from Free Shipping.</span>`;
            }
          }
        });
      } catch (err) {
        console.error('Free shipping bar error:', err);
      }
    }

    document.addEventListener('cart:updated', updateFsBar);
  })();
</script>
