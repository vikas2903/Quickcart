<style>
:root{
    --primary-color-progressbar: #000;
}
/* ── WRAPPER ── */
.discount-progress-wrap {
  background: transparent;
  padding: 6px 12px;
} 

/* ── MESSAGE ── */
.progress-message {
  font-size: 0.9rem; 
  color: #333;
  text-align: center;
  margin-bottom: 6px;
  line-height: 1.5;
  margin:0;
}
.progress-message strong { color: var(--primary-color-progressbar); }

/* ── TRACK ── */
.progress-track-wrap {
  position: relative;
  padding: 0 16px;
}
.progress-track {
  position: absolute;
  top: 14px; /* centers on icon */
  left: calc(16px + 22px);  /* starts at center of first icon */
  right: calc(16px + 22px); /* ends at center of last icon */
  height: 5px;
  background: #e0e0e0;
  border-radius: 10px;
  overflow: hidden;
  z-index: 0;
}
.progress-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(to right, var(--primary-color-progressbar), var(--primary-color-progressbar));
  border-radius: 10px;
  transition: width 0.6s cubic-bezier(.4,0,.2,1);
}

/* ── STEPS ROW ── */
.progress-steps {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}

/* ── SINGLE STEP ── */
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  flex: 1;
}

/* ── ICON CIRCLE ── */
.step-icon {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #f0f0f0;
  border: 2.5px solid #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.4s, border-color 0.4s, box-shadow 0.4s;
  position: relative;
}
.step-icon svg {
  width: 20px;
  height: 20px;
  color: #999;
  transition: color 0.4s;
}

/* ACTIVE state */
.step.active .step-icon {
  background: #fff;
  border-color: var(--primary-color-progressbar);
}
.step.active .step-icon svg { color: var(--primary-color-progressbar); }

/* UNLOCKED/completed state */
.step.unlocked .step-icon {
  background: linear-gradient(135deg, var(--primary-color-progressbar), var(--primary-color-progressbar));
  border-color: var(--primary-color-progressbar);
}
.step.unlocked .step-icon svg { color: #fff; }

/* Checkmark overlay for unlocked */
.step.unlocked .step-icon::after {
  content: '✓';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  color: #fff;
  font-weight: 700;
}
.step.unlocked .step-icon svg { display: none; }

/* ── LABELS ── */
.step-label {
  font-size: 0.78rem;
  font-weight: 600;
  color: #999;
  text-align: center;
  line-height: 1.4;
  transition: color 0.3s;
}
.step-label small {
  font-size: 0.7rem;
  font-weight: 400;
  display: block;
  margin-top: 2px;
}
.step.active .step-label,
.step.unlocked .step-label { color: var(--primary-color-progressbar); }

</style>
  
  

  <div class="discount-progress-wrap" data-qty-tier-progress>
    <p class="progress-message" id="progressMessage" data-progress-message>
    Add <strong>1 item</strong> to unlock <strong>10% OFF</strong>!
    </p>

    <div class="progress-track-wrap">
      <!-- Filled track -->
      <div class="progress-track">
        <div class="progress-fill" id="progressFill" data-progress-fill></div>
      </div>

      <!-- Steps -->
      <div class="progress-steps">

        <div class="step" id="step1" data-step-qty="1" data-step-label="10% OFF" data-step-buy="Buy 1">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
              <line x1="3" y1="6" x2="21" y2="6" />
              <path d="M16 10a4 4 0 01-8 0" />
            </svg>
          </div>
          <div class="step-label"></div>
        </div>

        <div class="step" id="step2" data-step-qty="2" data-step-label="15% OFF" data-step-buy="Buy 2">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <polyline points="20 12 20 22 4 22 4 12" />
              <rect x="2" y="7" width="20" height="5" />
              <line x1="12" y1="22" x2="12" y2="7" />
              <path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z" />
              <path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z" />
            </svg>
          </div>
          <div class="step-label"></div>
        </div>

        <div class="step" id="step3" data-step-qty="3" data-step-label="20% OFF" data-step-buy="Buy 3">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="12" cy="8" r="6" />
              <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11" />
            </svg>
          </div>

          <div class="step-label"></div>
          
        </div>

      </div>
    </div>
  </div>

